{
  "name": "score-keeper",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate": "node scripts/gen-3d-dice.cjs && node scripts/gen-icon-variants.cjs && node -e \"const fs=require('fs');fs.copyFileSync('public/icon-preview-3d-192.png','public/pwa-192.png');fs.copyFileSync('public/icon-preview-3d-512.png','public/pwa-512.png');fs.copyFileSync('public/icon-preview-3d-maskable-512.png','public/pwa-maskable-512.png');console.log('PWA icons -> 3D dice ✓');\"",
    "dev": "npm run generate && vite",
    "build": "npm run generate && vite build",
    "test": "vitest run --reporter=verbose --reporter=github-actions",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify/react": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
